# Directus backend. When DIRECTUS_URL is set, pages read live content and the
# missionary portal (login + submissions) is enabled; when unset, the site
# renders from the local mock fixtures (see src/lib/content.ts).
DIRECTUS_URL=
# Static token for public content reads (a read-only role). Portal requests
# authenticate per-user and do not use this token.
DIRECTUS_TOKEN=
# Canonical public origin used in password-reset links (no trailing slash).
SITE_URL=http://localhost:3000
# Admin-only CLI scripts. Never configure this on the website service.
DIRECTUS_ADMIN_TOKEN=
