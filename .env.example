# Directus backend. When DIRECTUS_URL is set, pages read live content and the
# missionary portal (login + submissions) is enabled; when unset, the site
# renders from the local mock fixtures (see src/lib/content.ts).
DIRECTUS_URL=
# Optional Railway/private-network endpoint used only by server-side code.
# Keep DIRECTUS_URL public for local tooling; production should set this to
# http://${{directus.RAILWAY_PRIVATE_DOMAIN}}:8055.
DIRECTUS_INTERNAL_URL=
# Server-only Website service token for public reads and constrained draft
# mutations. Portal sessions authenticate per-user before it is used.
DIRECTUS_TOKEN=
# Canonical public origin used in password-reset links (no trailing slash).
SITE_URL=http://localhost:3000
# Admin-only CLI scripts. Never configure this on the website service.
DIRECTUS_ADMIN_TOKEN=
